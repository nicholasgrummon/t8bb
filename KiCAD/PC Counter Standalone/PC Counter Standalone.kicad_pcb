	(gr_text "PROGRAM COUNTER"
		(at 173.745 118.495 270)
		(layer "B.SilkS")
		(uuid "4b694507-7fe9-4eb2-9dc1-cce1ea003fbe")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
				(bold yes)
			)
			(justify left bottom mirror)
		)
	)
	(gr_text "The heart of any computer architecture.\nThe PC Register holds the PROG MEM address of\nthe current instruction.\nWith every clock pulse, the address is incremented\nby one -via the Adder- to read through a program.\nThe Schmitt Trigger removes bounce in the clock.\nThe input bus allows the PC to optionally branch\nand return through the program non-sequentially.\n"
		(at 172.745 118.245 270)
		(layer "B.SilkS")
		(uuid "9c6cccd5-7c3d-42cb-a7b9-93d7b36e052c")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
			(justify left top mirror)
