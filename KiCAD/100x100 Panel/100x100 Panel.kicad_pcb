	(gr_text "DIP Switches are used\nto manually enter words\ninto PROG & DATA MEM.\nThe WRITE push-buttons\ntrigger each event.\nThe EN WRITE switch\nenables programming\nmode."
		(at 179 60.492498 180)
		(layer "B.SilkS")
		(uuid "01a21b08-8c78-4a89-90f2-3d6990efbe67")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
			(justify left top mirror)
		)
	)
	(gr_text "The heart of any computer architecture.\nThe PC Register holds the PROG MEM address of\nthe current instruction.\nWith every clock pulse, the address is incremented\nby one -via the Adder- to read through a program.\nThe Schmitt Trigger removes bounce in the clock.\nThe input bus allows the PC to optionally branch\nand return through the program non-sequentially.\n"
		(at 157 135.5 -90)
		(layer "B.SilkS")
		(uuid "345ac346-cd3f-4ab4-85e4-c996580c40b2")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
			(justify left top mirror)
		)
	)
	(gr_text "USER INPUT"
		(at 178.8 63.192498 180)
		(layer "B.SilkS")
		(uuid "6a46c6d1-b0a5-49e1-afe0-99fbd747d74a")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
				(bold yes)
			)
			(justify left top mirror)
		)
	)
	(gr_text "Bulk memory that stores all user-input information,\nincluding program instructions or data variables.\nSeparate RAM is used for each type in ARM architecture.\nStored values are eight bits and are called words."
		(at 150.5 41.75 0)
		(layer "B.SilkS")
		(uuid "9b16dde7-9014-4f1b-aed8-f31940d148f3")
		(effects
